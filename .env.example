# Yandex Foundation Models
# Fill these values in your local .env file. Never commit real keys.
YANDEX_CLOUD_FOLDER=
YANDEX_API_KEY=

# Optional local model paths.
# Leave empty to resolve from Hugging Face cache/model id, or point to local folders.
EMBEDDING_MODEL_PATH=
RERANKER_MODEL_PATH=

# Optional Hugging Face cache location.
# Example for local/offline deployments: ./data/_hf_cache
HF_HOME=

# Keep models offline when they are already downloaded locally.
HF_LOCAL_FILES_ONLY=1
